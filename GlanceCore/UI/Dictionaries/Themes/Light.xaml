<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="ThemeText" Color="#111111"/>
    <SolidColorBrush x:Key="ThemeTextMuted" Color="#666666"/>
    <SolidColorBrush x:Key="ThemeIconColor" Color="#222222"/>
    <SolidColorBrush x:Key="ThemeControlBg" Color="#20000000"/>
    <LinearGradientBrush x:Key="ThemeBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E0EAFC" Offset="0.0"/>
        <GradientStop Color="#CFDEF3" Offset="0.5"/>
        <GradientStop Color="#E0EAFC" Offset="1.0"/>
    </LinearGradientBrush>
</ResourceDictionary>