                                                                            <Button Tag="{Binding Id}" Click="BtnWidgetSettings_Click" Style="{StaticResource GearBtnStyle}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                                            <CheckBox Tag="{Binding Id}" IsChecked="{Binding IsActive, Mode=OneWay}" Style="{StaticResource AppleSwitchStyle}" Click="ToggleDynamicWidget_Click"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
