                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{DynamicResource Lang_Prop_Topmost}" Foreground="{DynamicResource ThemeText}" FontSize="15" FontWeight="SemiBold"/>
