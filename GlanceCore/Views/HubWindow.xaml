                                                    </StackPanel>
                                                    <CheckBox x:Name="TglWidgetTopmost" Grid.Column="1" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="Topmost_Changed"/>
