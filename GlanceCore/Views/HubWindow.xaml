<Window x:Class="GlanceCore.Views.HubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:GlanceCore"
        xmlns:widgets="clr-namespace:GlanceCore.Widgets"
        xmlns:Core="clr-namespace:GlanceCore.Core"
        Title="GlanceCore Hub" 
        Height="650" Width="950"
        MinHeight="550" MinWidth="800"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        TextElement.Foreground="#FFFFFF" SnapsToDevicePixels="True" UseLayoutRounding="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="8" GlassFrameThickness="-1"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Storyboard x:Key="AmbientGradientAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <ColorAnimation Storyboard.TargetName="Color1" Storyboard.TargetProperty="Color" To="#2A0845" Duration="0:0:8" />
            <ColorAnimation Storyboard.TargetName="Color2" Storyboard.TargetProperty="Color" To="#6441A5" Duration="0:0:12" />
            <ColorAnimation Storyboard.TargetName="Color3" Storyboard.TargetProperty="Color" To="#151525" Duration="0:0:10" />
        </Storyboard>
        <!-- Элегантный Apple-style Slider -->

        <Style x:Key="GearBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" RenderTransformOrigin="0.5,0.5">
                            <iconPacks:PackIconLucide x:Name="GearIcon" Kind="Settings" Width="16" Height="16" Foreground="#A0FFFFFF" RenderTransformOrigin="0.5,0.5">
                                <iconPacks:PackIconLucide.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </iconPacks:PackIconLucide.RenderTransform>
                            </iconPacks:PackIconLucide>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GearIcon" Property="Foreground" Value="#8A2BE2"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GearIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="90" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GearIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="0" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#150E24"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="6" Margin="2">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#70521D8A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#9F521D8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#251535"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4F2E7A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.ColumnSpan="2" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" Background="#201030" BorderBrush="#4F2E7A" BorderThickness="1.5" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" x:Name="Arrow" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#2F1840"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#8A2BE2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="SubMenu" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#150E24" BorderBrush="#70521D8A" BorderThickness="1.5" CornerRadius="8" Margin="0,4,0,0">
                                        <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="24">
                            <!-- Фоновая дорожка -->
                            <Border Height="6" Background="#30FFFFFF" CornerRadius="3" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Background="#E0FFFFFF" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="{TemplateBinding Background}" CornerRadius="3,0,0,3"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="20" Height="20">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="White" Cursor="Hand">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.4"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Background="Transparent" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Стиль для социальных кнопок -->
        <Style x:Key="SocialBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#60FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TextLinkStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#80FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" TextDecorations="Underline"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Остальные стили (Тумблеры, Скролл, и т.д. остаются как были) -->
        <Style x:Key="AppleSwitchStyle" TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="50" Height="28" CornerRadius="14" Background="#20FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" Cursor="Hand">
                            <Ellipse x:Name="Thumb" Width="22" Height="22" Fill="White" HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#34C759"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" To="22" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="WinBtn">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HubTabStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="GroupName" Value="MenuTabs"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="10" Padding="15,0" Margin="0,4" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <ScrollContentPresenter />
                            <ScrollBar x:Name="PART_VerticalScrollBar" HorizontalAlignment="Right" Maximum="{TemplateBinding ScrollableHeight}" ViewportSize="{TemplateBinding ViewportHeight}" Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" Width="5"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#40FFFFFF" CornerRadius="3" Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="TransparentHoverButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToggleButton" x:Key="TransparentHoverToggleButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="WinCloseBtn" BasedOn="{StaticResource WinBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource AmbientGradientAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="16" BorderBrush="#40FFFFFF" BorderThickness="1" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="Color1" Color="#0F0C29" Offset="0.0"/>
                <GradientStop x:Name="Color2" Color="#302B63" Offset="0.5"/>
                <GradientStop x:Name="Color3" Color="#24243E" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ШАПКА -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ToggleButton x:Name="BtnMenuToggle" Grid.Column="0" Click="BtnMenuToggle_Click" Style="{StaticResource TransparentHoverToggleButtonStyle}" FontFamily="Segoe MDL2 Assets" Content="&#xE700;" FontSize="16" Foreground="White"/>
                <Border Grid.Column="1" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource WinBtn}" Content="&#xE921;" Click="BtnMinimize_Click"/>
                    <Button Style="{StaticResource WinBtn}" Content="&#xE922;" Click="BtnMaximize_Click"/>
                    <Button Style="{StaticResource WinCloseBtn}" Content="&#xE8BB;" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- КОНТЕНТ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- БОКОВОЕ МЕНЮ -->
                <Border x:Name="Sidebar" Grid.Column="0" Width="220" ClipToBounds="True">
                    <Grid Margin="15,10,0,20">
                        <TextBlock Text="GlanceCore" FontSize="20" FontWeight="Bold" Margin="10,0,0,30" FontFamily="Segoe Print" VerticalAlignment="Top"/>

                        <Grid Margin="0,50,0,0">
                            <Border x:Name="SelectionPill" Background="#35FFFFFF" CornerRadius="10" Height="42" VerticalAlignment="Top" Margin="0,0,15,0" IsHitTestVisible="False">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="PillTransform" Y="4"/>
                                </Border.RenderTransform>
                            </Border>

                            <StackPanel x:Name="MenuStack" Margin="0,0,15,0">
                                <RadioButton x:Name="TabWidgets" Style="{StaticResource HubTabStyle}" IsChecked="True" Checked="Tab_Checked">
                                    <Grid>
                                        <TextBlock Text="Виджеты" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <iconPacks:PackIconLucide Kind="LayoutDashboard" Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
                                    </Grid>
                                </RadioButton>
                                <RadioButton x:Name="TabStore" Style="{StaticResource HubTabStyle}" Checked="Tab_Checked">
                                    <Grid>
                                        <TextBlock Text="Магазин" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <iconPacks:PackIconLucide Kind="ShoppingBag" Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
                                    </Grid>
                                </RadioButton>
                                <RadioButton x:Name="TabSettings" Style="{StaticResource HubTabStyle}" Checked="Tab_Checked">
                                    <Grid>
                                        <TextBlock Text="Настройки" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <iconPacks:PackIconLucide Kind="Settings" Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
                                    </Grid>
                                </RadioButton>
                            </StackPanel>
                        </Grid>

                        <!-- СОЦИАЛЬНЫЕ КНОПКИ (В самом низу Sidebar) -->
                        <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,15,0">
                            <Button Style="{StaticResource SocialBtnStyle}" Tag="https://discord.gg/" Click="OpenLink_Click" ToolTip="Discord">
                                <iconPacks:PackIconSimpleIcons Kind="Discord" Width="14" Height="14"/>
                            </Button>
                            <Button Style="{StaticResource SocialBtnStyle}" Tag="https://reddit.com/" Click="OpenLink_Click" ToolTip="Reddit">
                                <iconPacks:PackIconSimpleIcons Kind="Reddit" Width="14" Height="14"/>
                            </Button>
                            <Button Style="{StaticResource SocialBtnStyle}" Tag="https://tiktok.com/" Click="OpenLink_Click" ToolTip="TikTok">
                                <iconPacks:PackIconSimpleIcons Kind="TikTok" Width="14" Height="14"/>
                            </Button>
                            <Button Style="{StaticResource SocialBtnStyle}" Tag="https://x.com/" Click="OpenLink_Click" ToolTip="X (Twitter)">
                                <iconPacks:PackIconSimpleIcons Kind="X" Width="14" Height="14"/>
                            </Button>

                            <!-- КНОПКА ABOUT (Выделяется размером) -->
                            <Button Style="{StaticResource SocialBtnStyle}" Click="BtnAbout_Click" ToolTip="О программе" Margin="10,0,0,0">
                                <iconPacks:PackIconLucide Kind="Info" Width="20" Height="20" Foreground="White"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- РАБОЧАЯ ЗОНА -->
                <Border Grid.Column="1" Background="#15FFFFFF" CornerRadius="12" Margin="15,0,15,15" BorderBrush="#20FFFFFF" BorderThickness="1">
                    <ContentControl x:Name="ActiveTabContent" RenderTransformOrigin="0.5,0.5">
                        <ContentControl.RenderTransform>
                            <ScaleTransform x:Name="ContentScale" ScaleX="1" ScaleY="1"/>
                        </ContentControl.RenderTransform>

                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" x:Name="TabTitleText" Text="Управление виджетами" Foreground="#E0E0E0" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

                            <Grid Grid.Row="1">
                                <!-- ВКЛАДКА 1: ВИДЖЕТЫ -->
                                <Grid x:Name="WidgetsPanel" Visibility="Visible">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="WidgetsList" Margin="0,0,10,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="{Binding Width}" Height="180" CornerRadius="20" Margin="0,0,15,20" BorderBrush="#20FFFFFF" BorderThickness="1" ClipToBounds="True" Background="#05FFFFFF">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Image Grid.Row="0" Source="{Binding PreviewImage}" Stretch="Uniform" Opacity="0.8"/>
                                                            <Border Grid.Row="0" Background="#10000000"/>
                                                            <Border Grid.Row="1" Height="60" Background="#15FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" CornerRadius="0,0,19,19" Margin="-1,0,-1,-1">
                                                                <Grid Margin="15,0">
                                                                    <StackPanel VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#90FFFFFF" TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                        <Button Tag="{Binding Id}" Click="BtnWidgetSettings_Click" Style="{StaticResource TransparentHoverButtonStyle}" Margin="0,0,12,0">
                                                                            <iconPacks:PackIconLucide Kind="Settings" Width="16" Height="16" Foreground="#A0FFFFFF"/>
                                                                        </Button>
