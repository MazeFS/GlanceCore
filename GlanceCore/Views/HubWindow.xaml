                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                </Grid>

                                                <TextBlock Text="{DynamicResource Lang_Prop_Width}" Foreground="{DynamicResource ThemeText}" Opacity="0.6" Margin="0,10,0,5"/>
