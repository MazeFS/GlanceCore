                                                    <TextBox x:Name="TxtRadius" Grid.Column="1" Width="60" Height="28" Margin="15,0,0,0" Background="#20FFFFFF" Foreground="White" BorderThickness="0" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="13" FontWeight="SemiBold" TextChanged="SizeInput_TextChanged">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                    
                                                </Grid>
                                                <Grid Margin="0,10,0,15">
