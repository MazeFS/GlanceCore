                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{DynamicResource Lang_Date_ColorDay}" Foreground="White" Opacity="0.6" Margin="0,0,0,5" FontSize="11"/>
                                                            <Button Tag="DateDay" Click="BtnPickColor_Click" Width="32" Height="32" HorizontalAlignment="Left" Style="{StaticResource TransparentHoverButtonStyle}" Cursor="Hand">
                                                                <Ellipse x:Name="CircleDateDayColor" Width="30" Height="30" Fill="White" Stroke="#40FFFFFF" StrokeThickness="2"/>
                                                            </Button>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{DynamicResource Lang_Date_ColorDate}" Foreground="White" Opacity="0.6" Margin="0,0,0,5" FontSize="11"/>
                                                            <Button Tag="DateDate" Click="BtnPickColor_Click" Width="32" Height="32" HorizontalAlignment="Left" Style="{StaticResource TransparentHoverButtonStyle}" Cursor="Hand">
                                                                <Ellipse x:Name="CircleDateDateColor" Width="30" Height="30" Fill="White" Stroke="#40FFFFFF" StrokeThickness="2"/>
                                                            </Button>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="{DynamicResource Lang_Date_ColorTime}" Foreground="White" Opacity="0.6" Margin="0,0,0,5" FontSize="11"/>
                                                            <Button Tag="DateTime" Click="BtnPickColor_Click" Width="32" Height="32" HorizontalAlignment="Left" Style="{StaticResource TransparentHoverButtonStyle}" Cursor="Hand">
                                                                <Ellipse x:Name="CircleDateTimeColor" Width="30" Height="30" Fill="White" Stroke="#40FFFFFF" StrokeThickness="2"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,10,0,15">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Lang_Date_Plate}" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{DynamicResource Lang_Date_Plate_Desc}" Foreground="#80FFFFFF" FontSize="12"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="TglShowPlate" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="DateSettings_Changed"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,15">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Lang_Date_ShowDay}" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="TglShowDay" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="DateSettings_Changed"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,15">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Lang_Date_ShowDate}" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="TglShowCalendarDate" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="DateSettings_Changed"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,5">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Lang_Date_ShowTime}" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="TglShowClockTime" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="DateSettings_Changed"/>
                                                    </Grid>
                                                </StackPanel>
                                                <StackPanel x:Name="AiSettingsPanel" Visibility="Collapsed">
                                                    <Border Height="1" Background="#15FFFFFF" Margin="0,10"/>

                                                    <TextBlock Text="{DynamicResource Lang_AI_Endpoint}" Foreground="White" Opacity="0.6" Margin="0,10,0,5"/>
                                                    <TextBox x:Name="TxtAiEndpoint" Height="30" Background="#20FFFFFF" Foreground="White" BorderThickness="0" Padding="8,0" VerticalContentAlignment="Center" TextChanged="AiSettings_Changed">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>

                                                    <TextBlock Text="{DynamicResource Lang_AI_Key}" Foreground="White" Opacity="0.6" Margin="0,10,0,5"/>
                                                    <TextBox x:Name="TxtAiKey" Height="30" Background="#20FFFFFF" Foreground="White" BorderThickness="0" Padding="8,0" VerticalContentAlignment="Center" TextChanged="AiSettings_Changed">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>

                                                    <TextBlock Text="{DynamicResource Lang_AI_Model}" Foreground="White" Opacity="0.6" Margin="0,10,0,5"/>
                                                    <TextBox x:Name="TxtAiModel" Height="30" Background="#20FFFFFF" Foreground="White" BorderThickness="0" Padding="8,0" VerticalContentAlignment="Center" TextChanged="AiSettings_Changed">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>

                                                    <TextBlock Text="{DynamicResource Lang_AI_Prompt}" Foreground="White" Opacity="0.6" Margin="0,10,0,5"/>
                                                    <TextBox x:Name="TxtAiPrompt" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Background="#20FFFFFF" Foreground="White" BorderThickness="0" Padding="8,5" VerticalContentAlignment="Top" TextChanged="AiSettings_Changed">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>

                                                    <Grid Margin="0,10,0,5">
                                                        <TextBlock Text="{DynamicResource Lang_AI_Temp}" Foreground="White" Opacity="0.6" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Value, ElementName=SldAiTemp, StringFormat={}{0:F1}}" Foreground="White" Opacity="0.8" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    </Grid>
                                                    <Slider x:Name="SldAiTemp" Minimum="0.0" Maximum="1.5" ValueChanged="AiSlider_Changed"/>
                                                </StackPanel>

                                                <StackPanel x:Name="MediaSettingsPanel" Visibility="Collapsed">
                                                    <Border Height="1" Background="#15FFFFFF" Margin="0,10"/>
                                                    <Grid Margin="0,10,0,5">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Lang_Media_Timer}" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{DynamicResource Lang_Media_Timer_Desc}" Foreground="#80FFFFFF" FontSize="12"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="TglShowMediaTimer" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="MediaSettings_Changed"/>
                                                    </Grid>
                                                </StackPanel>

                                                <StackPanel x:Name="WeatherSettingsPanel" Visibility="Collapsed">
                                                    <Border Height="1" Background="#15FFFFFF" Margin="0,10"/>
                                                    <TextBlock Text="{DynamicResource Lang_Weather_City}" Foreground="White" Opacity="0.6" Margin="0,10,0,5"/>
                                                    <TextBox x:Name="TxtWeatherCity" Height="30" Background="#20FFFFFF" Foreground="White" BorderThickness="0" Padding="8,0" VerticalContentAlignment="Center" TextChanged="WeatherSettings_Changed">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                </StackPanel>
                                                <StackPanel x:Name="TypographySettingsPanel">
                                                    <Border Height="1" Background="#15FFFFFF" Margin="0,10"/>
                                                    <TextBlock Text="{DynamicResource Lang_Prop_Font}" Foreground="MediumPurple" Opacity="0.6" Margin="0,10,0,5"/>
                                                    <ComboBox x:Name="ComboFont" SelectionChanged="ComboBox_SelectionChanged" Background="#20FFFFFF" Foreground="White" BorderThickness="0" Height="32" Margin="0,0,0,15">
                                                        <ComboBox.ItemContainerStyle>
                                                            <Style TargetType="ComboBoxItem">
                                                                <Setter Property="Background" Value="#150E24"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="Padding" Value="12,8"/>
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#30FFFFFF"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ComboBox.ItemContainerStyle>
                                                        <ComboBoxItem Content="Segoe UI Variable" FontFamily="Segoe UI Variable" FontSize="14"/>
                                                        <ComboBoxItem Content="Segoe UI" FontFamily="Segoe UI" FontSize="14"/>
                                                        <ComboBoxItem Content="Consolas" FontFamily="Consolas" FontSize="14"/>
                                                        <ComboBoxItem Content="Arial" FontFamily="Arial" FontSize="14"/>
                                                        <ComboBoxItem Content="Cascadia Code" FontFamily="Cascadia Code" FontSize="14"/>
                                                        <ComboBoxItem Content="Comic Sans MS" FontFamily="Comic Sans MS" FontSize="14"/>
                                                        <ComboBoxItem Content="Century Gothic" FontFamily="Century Gothic" FontSize="14"/>
                                                        <ComboBoxItem Content="Impact" FontFamily="Impact" FontSize="14"/>
                                                        <ComboBoxItem Content="Trebuchet MS" FontFamily="Trebuchet MS" FontSize="14"/>
                                                        <ComboBoxItem Content="Verdana" FontFamily="Verdana" FontSize="14"/>
                                                        <ComboBoxItem Content="Courier New" FontFamily="Courier New" FontSize="14"/>
                                                    </ComboBox>
                                                    <Button x:Name="BtnImportFont" Content="{DynamicResource Lang_Btn_ImportFont}" Click="BtnImportFont_Click" Background="#30FFFFFF" Foreground="White" Padding="10,6" BorderThickness="0" Cursor="Hand" Margin="0,0,0,15">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                    <TextBlock x:Name="LblFontSize" Text="{DynamicResource Lang_Prop_FontSize}" Foreground="White" Opacity="0.6" Margin="0,10,0,5"/>
                                                    <Slider x:Name="SldFontSize" Minimum="8" Maximum="30" ValueChanged="Slider_Changed"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </ScrollViewer>
                                </Grid>
                                
                                <!-- ВКЛАДКА 3: МАГАЗИН -->
                                <Grid x:Name="StorePanel" Visibility="Collapsed">
                                    <!-- СЛОЙ А: Главная сетка магазина (Список плагинов) -->
                                    <Grid x:Name="StoreMainGrid" Visibility="Visible">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- РЯД 0: Поиск и Воронка -->
                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{DynamicResource ThemeControlBg}" CornerRadius="8" Padding="10,6" Width="200" HorizontalAlignment="Left">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <iconPacks:PackIconLucide Kind="Search" Width="14" Height="14" Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBox x:Name="TxtSearchStore" Grid.Column="1" Background="Transparent" Foreground="{DynamicResource ThemeText}" BorderThickness="0" VerticalContentAlignment="Center" TextChanged="TxtSearchStore_TextChanged" CaretBrush="{DynamicResource ThemeText}"/>
                                                </Grid>
                                            </Border>
                                            <!-- Кнопка Фильтра (Sliders вместо неподдерживаемой Filter) -->
                                            <!-- Кнопка Фильтра (List вместо Sliders во избежание сбоев конвертера) -->
                                            <Button Grid.Column="1" Click="BtnStoreFilter_Click" Style="{StaticResource TransparentHoverButtonStyle}" Cursor="Hand">
                                                <Border Background="{DynamicResource ThemeControlBg}" CornerRadius="8" Padding="8">
                                                    <iconPacks:PackIconLucide Kind="List" Width="16" Height="16" Foreground="{DynamicResource ThemeText}"/>
                                                </Border>
                                            </Button>
                                        </Grid>

                                        <!-- РЯД 1: Категории (Essentials, Skins, Premium) -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                                            <Button x:Name="TabStoreEssentials" Content="Essentials" Click="TabStoreCategory_Click" Tag="Essentials" Style="{StaticResource TransparentHoverButtonStyle}" Foreground="MediumPurple" FontWeight="Bold" FontSize="14" Margin="0,0,25,0" Cursor="Hand"/>
                                            <Button x:Name="TabStoreSkins" Content="Skins" Click="TabStoreCategory_Click" Tag="Skins" Style="{StaticResource TransparentHoverButtonStyle}" Foreground="#80FFFFFF" FontWeight="Bold" FontSize="14" Margin="0,0,25,0" Cursor="Hand"/>
                                            <Button x:Name="TabStorePremium" Content="Premium" Click="TabStoreCategory_Click" Tag="Premium" Style="{StaticResource TransparentHoverButtonStyle}" Foreground="#80FFFFFF" FontWeight="Bold" FontSize="14" Cursor="Hand"/>
                                        </StackPanel>

                                        <!-- РЯД 2: Список карточек -->
                                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="StoreList" Margin="0,0,10,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="220" Height="180" CornerRadius="20" Margin="0,0,15,20" BorderBrush="#20FFFFFF" BorderThickness="1" ClipToBounds="True" Background="#05FFFFFF">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Image Grid.Row="0" Source="{Binding PreviewImage}" Stretch="Uniform" Opacity="0.8"/>
                                                                <Border Grid.Row="0" Background="#10000000"/>
                                                                <Border Grid.Row="1" Height="60" Background="#15FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" CornerRadius="0,0,19,19" Margin="-1,0,-1,-1">
                                                                    <Grid Margin="15,0">
                                                                        <StackPanel VerticalAlignment="Center" Width="100">
                                                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource ThemeText}" TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text="{Binding RatingStars}" FontSize="9" Foreground="Gold" Margin="0,2,0,0"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                            <Button Click="BtnStoreInfo_Click" Style="{StaticResource TransparentHoverButtonStyle}" Margin="0,0,8,0" Cursor="Hand">
                                                                                <Border Background="#20FFFFFF" CornerRadius="6" Padding="8,6">
                                                                                    <iconPacks:PackIconLucide Kind="Info" Width="13" Height="13" Foreground="White"/>
                                                                                </Border>
                                                                            </Button>
                                                                            <Button Click="BtnInstallPlugin_Click" Style="{StaticResource TransparentHoverButtonStyle}" Cursor="Hand">
                                                                                <Border x:Name="BtnGetBorder" Background="#8A2BE2" CornerRadius="6" Padding="12,6">
                                                                                    <TextBlock x:Name="BtnGetText" Text="GET" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                                                </Border>
                                                                            </Button>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                                                <Setter TargetName="BtnGetBorder" Property="Background" Value="#30FFFFFF"/>
                                                                <Setter TargetName="BtnGetText" Property="Text" Value="GOT"/>
                                                                <Setter TargetName="BtnGetText" Property="Foreground" Value="#60FFFFFF"/>
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>

                                    <!-- СЛОЙ Б: Детальная карточка плагина -->
                                    <Grid x:Name="StoreDetailsGrid" Visibility="Collapsed" Margin="10,0,10,20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Button Grid.Row="0" Click="BtnStoreBack_Click" Style="{StaticResource TransparentHoverButtonStyle}" Margin="0,0,0,20" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Background="Transparent" Cursor="Hand">
                                                <Border Background="#20FFFFFF" CornerRadius="8" Padding="6">
                                                    <iconPacks:PackIconLucide Kind="ChevronLeft" Width="16" Height="16" Foreground="White" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource Lang_Btn_Back}" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Height="140" CornerRadius="16" ClipToBounds="True" VerticalAlignment="Top" BorderThickness="1.5" BorderBrush="#20FFFFFF">
                                                <Grid>
                                                    <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                                                    <Border Background="#40000000"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="25,0,0,0">
                                                <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ThemeText}"/>
                                                <TextBlock Text="{Binding Author}" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding RatingStars}" FontSize="14" Foreground="Gold" Margin="0,8,0,0"/>

                                                <TextBlock Text="{Binding Description}" FontSize="14" Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap" Margin="0,20,0,25" LineHeight="22"/>

                                                <Button Click="BtnInstallPlugin_Click" Style="{StaticResource TransparentHoverButtonStyle}" HorizontalAlignment="Left" Cursor="Hand">
                                                    <Border x:Name="BtnDetailGetBorder" Background="#8A2BE2" CornerRadius="8" Padding="25,10">
                                                        <TextBlock x:Name="BtnDetailGetText" Text="Download" Foreground="White" FontSize="13" FontWeight="Bold"/>
                                                    </Border>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Grid>

                                <!-- ВКЛАДКА 4: НАСТРОЙКИ СИСТЕМЫ И ДОНАТ -->
                                <Grid x:Name="SettingsPanel" Visibility="Collapsed">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Margin="0,0,10,0">
                                            <Border Background="#15000000" CornerRadius="16" Padding="20" BorderBrush="#20FFFFFF" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Lang_Sys_Title}" Foreground="{DynamicResource ThemeText}" Opacity="0.5" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                                                    <TextBlock Text="{DynamicResource Lang_Sys_Theme}" Foreground="{DynamicResource ThemeText}" Opacity="0.6" Margin="0,0,0,5"/>
                                                    <ComboBox x:Name="ComboLang" SelectionChanged="ComboLang_SelectionChanged" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,20">
                                                        <ComboBoxItem Content="Русский" Tag="RU"/>
                                                        <ComboBoxItem Content="English" Tag="EN"/>
                                                    </ComboBox>
                                                    <TextBlock Text="Тема оформления Hub" Foreground="{DynamicResource ThemeText}" Opacity="0.6" Margin="0,0,0,10"/>
                                                    <ListBox x:Name="CarouselThemes" SelectionChanged="CarouselThemes_SelectionChanged" Background="Transparent" BorderThickness="0" Margin="0,0,0,20" Height="100" ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                                                        <ListBox.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <VirtualizingStackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ListBox.ItemsPanel>
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Margin" Value="0,0,15,0"/>
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="ListBoxItem">
                                                                            <Border x:Name="Card" Width="100" Height="75" Background="#150E24" CornerRadius="12" BorderBrush="#30FFFFFF" BorderThickness="1.5">
                                                                                <Grid>
                                                                                    <Border x:Name="ThemePreview" Height="26" CornerRadius="6" Margin="10,10,10,0" VerticalAlignment="Top" BorderThickness="1" BorderBrush="#20FFFFFF"/>
                                                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource ThemeText}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"/>
                                                                                    <Border x:Name="ActiveRing" BorderBrush="#8A2BE2" BorderThickness="2" CornerRadius="12" Visibility="Collapsed"/>
                                                                                </Grid>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsSelected" Value="True">
                                                                                    <Setter TargetName="ActiveRing" Property="Visibility" Value="Visible"/>
                                                                                    <Setter TargetName="Card" Property="BorderBrush" Value="#8A2BE2"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="Card" Property="BorderBrush" Value="#60FFFFFF"/>
                                                                                </Trigger>
                                                                                <DataTrigger Binding="{Binding Id}" Value="Original">
                                                                                    <Setter TargetName="ThemePreview" Property="Background">
                                                                                        <Setter.Value>
                                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                                <GradientStop Color="#0F0C29" Offset="0"/>
                                                                                                <GradientStop Color="#302B63" Offset="1"/>
                                                                                            </LinearGradientBrush>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Id}" Value="Dark">
                                                                                    <Setter TargetName="ThemePreview" Property="Background">
                                                                                        <Setter.Value>
                                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                                <GradientStop Color="#0A0A0C" Offset="0"/>
                                                                                                <GradientStop Color="#141518" Offset="1"/>
                                                                                            </LinearGradientBrush>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Id}" Value="Blue">
                                                                                    <Setter TargetName="ThemePreview" Property="Background">
                                                                                        <Setter.Value>
                                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                                <GradientStop Color="#000428" Offset="0"/>
                                                                                                <GradientStop Color="#004e92" Offset="1"/>
                                                                                            </LinearGradientBrush>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Id}" Value="Light">
                                                                                    <Setter TargetName="ThemePreview" Property="Background">
                                                                                        <Setter.Value>
                                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                                <GradientStop Color="#E0EAFC" Offset="0"/>
                                                                                                <GradientStop Color="#CFDEF3" Offset="1"/>
                                                                                            </LinearGradientBrush>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <ContentPresenter/>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>

                                                    <Grid Margin="0,0,0,15">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Lang_Sys_Autostart}" Foreground="{DynamicResource ThemeText}" FontSize="15" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{DynamicResource Lang_Sys_Autostart_Desc}" Foreground="{DynamicResource ThemeTextMuted}" FontSize="12"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="TglAutoStart" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="SystemSettings_Changed"/>
                                                    </Grid>
                                                    <Border Height="1" Background="#15FFFFFF" Margin="0,0,0,15"/>
                                                    <Grid Margin="0,0,0,15">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Lang_Sys_Lock}" Foreground="{DynamicResource ThemeText}" FontSize="15" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{DynamicResource Lang_Sys_Lock_Desc}" Foreground="{DynamicResource ThemeTextMuted}" FontSize="12"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="TglLock" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="SystemSettings_Changed"/>
                                                    </Grid>
                                                    <Border Height="1" Background="#15FFFFFF" Margin="0,0,0,15"/>
                                                    <Grid Margin="0,0,0,15">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Lang_Sys_Shader}" Foreground="{DynamicResource ThemeText}" FontSize="15" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{DynamicResource Lang_Sys_Shader_Desc}" Foreground="{DynamicResource ThemeTextMuted}" FontSize="12"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="TglShader" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="SystemSettings_Changed"/>
                                                    </Grid>
                                                    <Border Height="1" Background="#15FFFFFF" Margin="0,18,0,18"/>
                                                    <Grid Margin="0,5,0,0">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Lang_Sys_Streamer}" Foreground="{DynamicResource ThemeText}" FontSize="15" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{DynamicResource Lang_Sys_Streamer_Desc}" Foreground="{DynamicResource ThemeTextMuted}" FontSize="12"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="TglStreamerMode" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="SystemSettings_Changed"/>
                                                    </Grid>
                                                    <Border Height="1" Background="#15FFFFFF" Margin="0,18,0,18"/>
                                                    <Grid Margin="0,5,0,0">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Lang_Sys_Game}" Foreground="{DynamicResource ThemeText}" FontSize="15" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{DynamicResource Lang_Sys_Game_Desc}" Foreground="{DynamicResource ThemeTextMuted}" FontSize="12"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="TglGameMode" Style="{StaticResource AppleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="SystemSettings_Changed"/>
                                                    </Grid>
                                                    <Border Height="1" Background="#15FFFFFF" Margin="0,18,0,18"/>
                                                    <Grid>
                                                        <TextBlock Text="{DynamicResource Lang_Sys_IdleFps}" Foreground="{DynamicResource ThemeText}" Opacity="0.6" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Value, ElementName=SldIdleFps, StringFormat={}{0:F0} FPS}" Foreground="{DynamicResource ThemeText}" Opacity="0.8" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    </Grid>
                                                    <Slider x:Name="SldIdleFps" Minimum="5" Maximum="30" ValueChanged="SystemSettings_Changed" Margin="0,5,0,15"/>

                                                    <Grid>
                                                        <TextBlock Text="{DynamicResource Lang_Sys_MovingFps}" Foreground="{DynamicResource ThemeText}" Opacity="0.6" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Value, ElementName=SldMovingFps, StringFormat={}{0:F0} FPS}" Foreground="{DynamicResource ThemeText}" Opacity="0.8" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    </Grid>
                                                    <Slider x:Name="SldMovingFps" Minimum="24" Maximum="120" ValueChanged="SystemSettings_Changed" Margin="0,5,0,15"/>

                                                    <Border Height="1" Background="#15FFFFFF" Margin="0,18,0,18"/>
                                                    <Grid>
                                                        <TextBlock Text="{DynamicResource Lang_Sys_AutostartDelay}" Foreground="{DynamicResource ThemeText}" Opacity="0.6" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        <TextBlock Foreground="{DynamicResource ThemeText}" Opacity="0.8" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold">
                                                            <Run Text="{Binding Value, ElementName=SldStartupDelay, StringFormat={}{0:F0}}"/>
                                                            <Run Text=" "/>
                                                            <Run Text="{DynamicResource Lang_Sys_Sec}"/>
                                                        </TextBlock>
                                                    </Grid>
                                                    <Slider x:Name="SldStartupDelay" Minimum="0" Maximum="15" ValueChanged="SystemSettings_Changed" Margin="0,5,0,15"/>
                                                </StackPanel>
                                            </Border>
                                            <Border CornerRadius="20" Padding="2" Margin="0,25,0,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FFFFD700" Offset="0"/>
                                                        <GradientStop Color="#FFFF5E3A" Offset="0.5"/>
                                                        <GradientStop Color="#FFB24592" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#FF5E3A" Opacity="0.4"/>
                                                </Border.Effect>
                                                <Border Background="#E0101015" CornerRadius="18" Padding="25">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                                                            <TextBlock Text="{DynamicResource Lang_Donate_Title}" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                                                            <TextBlock Text="{DynamicResource Lang_Donate_Desc}" Foreground="#B0FFFFFF" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <Button Content="Buy Me a Coffee" Tag="https://www.buymeacoffee.com/" Click="OpenLink_Click" Background="#FFDD00" Foreground="Black" FontWeight="Bold" FontSize="13" Padding="20,10" BorderThickness="0" Cursor="Hand" Margin="0,0,0,10" FocusVisualStyle="{x:Null}">
                                                                <Button.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="10"/>
                                                                    </Style>
                                                                </Button.Resources>
                                                            </Button>
                                                            <Button Content="Поддержать на Boosty" Tag="https://boosty.to/" Click="OpenLink_Click" Background="#F15F2C" Foreground="White" FontWeight="Bold" FontSize="13" Padding="20,10" BorderThickness="0" Cursor="Hand" FocusVisualStyle="{x:Null}">
                                                                <Button.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="10"/>
                                                                    </Style>
                                                                </Button.Resources>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                                <!-- ВКЛАДКА ABOUT (О ПРОГРАММЕ) -->
                                <Grid x:Name="AboutPanel" Visibility="Collapsed">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Margin="0,0,15,20">
                                            <TextBlock Text="GLANCECORE" FontFamily="Segoe Print" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource Lang_About_Header}" FontSize="14" FontWeight="SemiBold" Foreground="#A0FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                                            <Border Background="#15000000" CornerRadius="16" Padding="25" BorderBrush="#20FFFFFF" BorderThickness="1" Margin="0,0,0,20">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Lang_About_Header}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                                                    <TextBlock Text="{DynamicResource Lang_About_Version}" FontSize="12" Foreground="#80FFA3" Margin="0,0,0,20"/>

                                                    <TextBlock Text="{DynamicResource Lang_About_ManifestTitle}" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                                                    <TextBlock Text="{DynamicResource Lang_About_ManifestText}" Foreground="#D0FFFFFF" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,20"/>

                                                    <TextBlock Text="{DynamicResource Lang_About_StackTitle}" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                                                    <TextBlock Text="{DynamicResource Lang_About_StackText}" Foreground="#A0FFFFFF" TextWrapping="Wrap" LineHeight="20" Margin="10,0,0,20"/>

                                                    <TextBlock Text="{DynamicResource Lang_About_TeamTitle}" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                                                    <TextBlock Text="{DynamicResource Lang_About_TeamText}" Foreground="#D0FFFFFF" TextWrapping="Wrap" LineHeight="20"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- ЮРИДИЧЕСКИЕ ССЫЛКИ НА GITHUB PAGES -->
                                            <Border Background="#10000000" CornerRadius="16" Padding="20" BorderBrush="#15FFFFFF" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <!-- Замени 'mazefs' на свой реальный логин GitHub -->
                                                    <Button Content="Privacy Policy" Tag="https://mazefs.github.io/GlanceCore/PRIVACY" Click="OpenLink_Click" Style="{StaticResource TextLinkStyle}"/>
                                                    <TextBlock Text="|" Foreground="#40FFFFFF" Margin="15,0"/>
                                                    <Button Content="Terms of Service" Tag="https://mazefs.github.io/GlanceCore/TERMS" Click="OpenLink_Click" Style="{StaticResource TextLinkStyle}"/>
                                                    <TextBlock Text="|" Foreground="#40FFFFFF" Margin="15,0"/>
                                                    <Button Content="F.A.Q." Tag="https://mazefs.github.io/GlanceCore/FAQ" Click="OpenLink_Click" Style="{StaticResource TextLinkStyle}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                            </Grid>
                        </Grid>
                    </ContentControl>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
