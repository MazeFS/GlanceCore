                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Slider x:Name="SldWidth" Minimum="100" Maximum="1000" ValueChanged="Slider_Changed" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="TxtWidth" Grid.Column="1" Width="60" Height="28" Margin="15,0,0,0" Background="#20FFFFFF" Foreground="White" BorderThickness="0" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="13" FontWeight="SemiBold" TextChanged="SizeInput_TextChanged">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                </Grid>

                                                <TextBlock Text="{DynamicResource Lang_Prop_Height}" Foreground="{DynamicResource ThemeText}" Opacity="0.6" Margin="0,10,0,5"/>
                                                <Grid Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Slider x:Name="SldHeight" Minimum="80" Maximum="1000" ValueChanged="Slider_Changed" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="TxtHeight" Grid.Column="1" Width="60" Height="28" Margin="15,0,0,0" Background="#20FFFFFF" Foreground="White" BorderThickness="0" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="13" FontWeight="SemiBold" TextChanged="SizeInput_TextChanged">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                </Grid>

                                                <TextBlock Text="{DynamicResource Lang_Prop_Radius}" Foreground="{DynamicResource ThemeText}" Opacity="0.6" Margin="0,10,0,5"/>
