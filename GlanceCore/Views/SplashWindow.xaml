<Window x:Class="GlanceCore.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Starting GlanceCore" Height="300" Width="500"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False">

	<Window.Resources>
		<!-- 1. Сначала определяем функции плавности (Easing Functions) -->
		<QuarticEase x:Key="EaseOutQuart" EasingMode="EaseOut"/>
		<ExponentialEase x:Key="EaseOutExp" EasingMode="EaseOut" Exponent="6"/>

		<!-- 2. Теперь анимации, которые их используют -->
		<Storyboard x:Key="BackgroundGlow" RepeatBehavior="Forever" AutoReverse="True">
			<ColorAnimation Storyboard.TargetName="GlowColor1" Storyboard.TargetProperty="Color" To="#2A0845" Duration="0:0:4" />
			<ColorAnimation Storyboard.TargetName="GlowColor2" Storyboard.TargetProperty="Color" To="#151525" Duration="0:0:3" />
		</Storyboard>

		<Storyboard x:Key="FadeInAnimation">
			<DoubleAnimation Storyboard.TargetProperty="Opacity"
							 From="0" To="1"
							 Duration="0:0:1.2"
							 EasingFunction="{StaticResource EaseOutQuart}"/>

			<DoubleAnimation Storyboard.TargetName="LogoTransform"
							 Storyboard.TargetProperty="Y"
							 From="30" To="0"
							 Duration="0:0:1.8"
							 EasingFunction="{StaticResource EaseOutExp}"/>

			<DoubleAnimation Storyboard.TargetName="LogoText"
							 Storyboard.TargetProperty="Opacity"
							 From="0" To="1"
							 Duration="0:0:2"/>
		</Storyboard>

		<!-- 3. Стили -->
		<Style x:Key="SplashProgressStyle" TargetType="ProgressBar">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ProgressBar">
						<Border Background="#15FFFFFF" CornerRadius="2">
							<Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="2">
								<Border.Effect>
									<DropShadowEffect Color="White" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
								</Border.Effect>
							</Border>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource BackgroundGlow}"/>
            <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <!-- Основной контейнер с мягкой тенью -->
    <Grid Margin="20">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="10" Direction="270" Opacity="0.5" Color="Black"/>
        </Grid.Effect>

        <Border CornerRadius="24" ClipToBounds="True" BorderBrush="#30FFFFFF" BorderThickness="1">
            <!-- Темный стеклянный фон -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop x:Name="GlowColor1" Color="#0F0C29" Offset="0"/>
                    <GradientStop x:Name="GlowColor2" Color="#1E1E2C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <!-- Блик сверху -->
                <Border CornerRadius="24" Margin="1" BorderBrush="#20FFFFFF" BorderThickness="1">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0" RadiusX="0.8" RadiusY="0.5">
                            <GradientStop Color="#15FFFFFF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Контент -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- ЛОГОТИП -->
                    <TextBlock x:Name="LogoText" Text="GlanceCore" FontFamily="Segoe Print" FontSize="42" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="LogoTransform" Y="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                    <TextBlock Text="Widget Ecosystem" FontFamily="Segoe UI Variable" FontSize="13" Foreground="#80FFFFFF" HorizontalAlignment="Center" Margin="0,-5,0,40"/>

                    <!-- СТРОКА ЗАГРУЗКИ -->
                    <StackPanel Width="260">
                        <TextBlock x:Name="LoadingStatus" Text="Initializing..." FontFamily="Segoe UI Variable" FontSize="11" Foreground="#90FFFFFF" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                        <ProgressBar x:Name="LoadingBar" Style="{StaticResource SplashProgressStyle}" Height="3" Maximum="100" Value="0" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>