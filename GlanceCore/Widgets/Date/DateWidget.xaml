<widgets:BaseWidgetWindow x:Class="GlanceCore.Widgets.Date.DateWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="clr-namespace:GlanceCore.Widgets"
        Title="Date" WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Grid x:Name="MainRoot" Width="320" Height="220" Margin="15">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.4" Color="Black"/>
        </Grid.Effect>

        <Border x:Name="BackgroundLayer" CornerRadius="{Binding WidgetCornerRadius}" BorderBrush="{Binding BorderColorBrush}" BorderThickness="1.5" ClipToBounds="True" Opacity="{Binding BgOpacity}">
            <Grid>
                <Border x:Name="GlassBase" CornerRadius="{Binding WidgetCornerRadius}">
                    <Border.Background>
                        <ImageBrush x:Name="WallpaperBrush" Stretch="Fill"/>
                    </Border.Background>
                </Border>
                <Border x:Name="MinimalBase" Background="{Binding BgColorBrush}" CornerRadius="{Binding WidgetCornerRadius}" Opacity="0.3"/>
                <Border x:Name="GlossBevel" CornerRadius="{Binding WidgetCornerRadius}" BorderBrush="#35FFFFFF" BorderThickness="1.5" Margin="1" IsHitTestVisible="False">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0" RadiusX="0.9" RadiusY="0.6">
                            <GradientStop Color="#25FFFFFF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Border>

		<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
			<TextBlock x:Name="DayOfWeekText" Text="{Binding DayOfWeek}" Foreground="{Binding DayColorBrush}" FontSize="{Binding DayFontSize}" FontWeight="SemiBold" HorizontalAlignment="Center" Effect="{Binding TextGlowEffect}" Margin="0,0,0,8"/>
			<TextBlock x:Name="DateText" Text="{Binding DateString}" Foreground="{Binding DateColorBrush}" FontSize="{Binding DateFontSize}" FontWeight="Light" HorizontalAlignment="Center" Effect="{Binding TextGlowEffect}" Margin="0,0,0,10"/>
			<TextBlock x:Name="TimeText" Text="{Binding TimeString}" Foreground="{Binding TimeColorBrush}" FontSize="{Binding TimeFontSize}" FontWeight="Bold" HorizontalAlignment="Center" Effect="{Binding TextGlowEffect}"/>
		</StackPanel>
    </Grid>
</widgets:BaseWidgetWindow>