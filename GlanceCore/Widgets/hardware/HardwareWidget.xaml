<widgets:BaseWidgetWindow x:Class="GlanceCore.Widgets.Hardware.HardwareWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="clr-namespace:GlanceCore.Widgets"
        xmlns:shaders="clr-namespace:GlanceCore.UI.Shaders"
        Title="Hardware" Height="220" Width="220"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

	<Window.ContextMenu>
		<ContextMenu Background="#1A1A1A" Foreground="White">
			<MenuItem Header="Закрыть виджет" Click="CloseWidget_Click"/>
		</ContextMenu>
	</Window.ContextMenu>

	<Window.Resources>
		<Style x:Key="IOSProgressBar" TargetType="ProgressBar">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ProgressBar">
						<!-- English: Use a Grid with a Background for the track -->
						<Grid x:Name="TemplateRoot" Height="{TemplateBinding Height}" SnapsToDevicePixels="True">
							<Border Background="#20FFFFFF" CornerRadius="4"/>

							<!-- English: The indicator track container -->
							<Border x:Name="PART_Track" Margin="0" />

							<!-- English: The actual moving part. Using a Decorator or Border with alignment -->
							<Border x:Name="PART_Indicator"
									HorizontalAlignment="Left"
									CornerRadius="4"
									Background="{TemplateBinding Foreground}"/>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>
	<!-- English: Main Container with fixed Size to prevent compression -->
	<Grid x:Name="MainRoot" Margin="10" Width="200" Height="200">
		<Grid.Effect>
			<DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.4"/>
		</Grid.Effect>

		<Border CornerRadius="28" BorderThickness="1.5" ClipToBounds="True">
			<Border.BorderBrush>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#80FFFFFF" Offset="0"/>
					<GradientStop Color="#10FFFFFF" Offset="0.5"/>
					<GradientStop Color="#40FFFFFF" Offset="1"/>
				</LinearGradientBrush>
			</Border.BorderBrush>

			<Grid>
				<Border x:Name="GlassBase" CornerRadius="28">
					<Border.Background>
						<ImageBrush x:Name="WallpaperBrush" Stretch="Fill"/>
					</Border.Background>
				</Border>

				<Border CornerRadius="28" Background="#45000000" IsHitTestVisible="False"/>

				<!-- 5. UI CONTENT (Updated with dynamic font binding) -->
				<Grid Margin="22" IsHitTestVisible="False">
					<StackPanel VerticalAlignment="Center">
						<!-- Header -->
						<TextBlock Text="SYSTEM"
								   FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
								   FontWeight="Black" Foreground="White" Opacity="0.5"
								   HorizontalAlignment="Center" Margin="0,0,0,16"/>

						<!-- CPU Section -->
						<Grid Margin="0,0,0,6">
							<TextBlock Text="CPU"
									   FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
									   Foreground="#C0FFFFFF" HorizontalAlignment="Left" FontWeight="Medium"/>
							<TextBlock Text="{Binding CpuText}"
									   FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
									   Foreground="White" HorizontalAlignment="Right" FontWeight="Bold"/>
						</Grid>
						<ProgressBar Style="{StaticResource IOSProgressBar}" Value="{Binding CpuValue}" Height="8" BorderThickness="0" Foreground="White"/>

						<!-- GPU Section -->
						<Grid Margin="0,20,0,6">
							<TextBlock Text="GPU"
									   FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
									   Foreground="#C0FFFFFF" HorizontalAlignment="Left" FontWeight="Medium"/>
							<TextBlock Text="{Binding GpuText}"
									   FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
									   Foreground="White" HorizontalAlignment="Right" FontWeight="Bold"/>
						</Grid>
						<ProgressBar Style="{StaticResource IOSProgressBar}" Value="{Binding GpuValue}" Height="8" BorderThickness="0" Foreground="White"/>
					</StackPanel>
				</Grid>
			</Grid>
		</Border>
	</Grid>
</widgets:BaseWidgetWindow>