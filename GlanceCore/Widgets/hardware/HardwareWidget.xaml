<widgets:BaseWidgetWindow x:Class="GlanceCore.Widgets.Hardware.HardwareWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="clr-namespace:GlanceCore.Widgets"
        Title="Hardware" WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

	<Window.Resources>
		<Style x:Key="IOSProgressBar" TargetType="ProgressBar">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ProgressBar">
						<Grid x:Name="TemplateRoot" Height="{TemplateBinding Height}">
							<Border Background="#20FFFFFF" CornerRadius="3"/>
							<Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3" Background="{TemplateBinding Foreground}"/>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Grid x:Name="MainRoot" Width="220" Height="320" Margin="15">
		<Grid.Effect>
			<DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.4"/>
		</Grid.Effect>

		<!-- СЛОЙ 1: ФОН (Именно он реагирует на ползунок прозрачности BgOpacity) -->
		<Border x:Name="BackgroundLayer" CornerRadius="{Binding WidgetCornerRadius}" BorderBrush="{Binding BorderColorBrush}" BorderThickness="1.5" ClipToBounds="True" Opacity="{Binding BgOpacity}">
			<Grid>
				<!-- Стекло -->
				<Border x:Name="GlassBase" CornerRadius="{Binding WidgetCornerRadius}">
					<Border.Background>
						<ImageBrush x:Name="WallpaperBrush" Stretch="Fill"/>
					</Border.Background>
				</Border>

				<!-- 2. Цветная тонировка из Хаба (Полупрозрачная, чтобы стекло просвечивало!) -->
				<Border x:Name="MinimalBase" Background="{Binding BgColorBrush}" CornerRadius="{Binding WidgetCornerRadius}" Opacity="0.3"/>

				<!-- 3. Базовое затемнение (Чтобы белый текст всегда читался на светлых обоях) -->
				<Border Background="#30000000" CornerRadius="{Binding WidgetCornerRadius}"/>

				<!-- 4. Блики по краям -->
				<Border x:Name="GlossBevel" CornerRadius="{Binding WidgetCornerRadius}" BorderBrush="#35FFFFFF" BorderThickness="1.5" Margin="1">
					<Border.Background>
						<RadialGradientBrush Center="0.5,0" RadiusX="0.9" RadiusY="0.6">
							<GradientStop Color="#25FFFFFF" Offset="0"/>
							<GradientStop Color="Transparent" Offset="1"/>
						</RadialGradientBrush>
					</Border.Background>
				</Border>
			</Grid>
		</Border>

		<!-- СЛОЙ 2: КОНТЕНТ (Всегда 100% непрозрачный) -->
		<Grid Margin="20" IsHitTestVisible="False">
			<StackPanel VerticalAlignment="Center">
				<TextBlock x:Name="TitleText" Text="SYSTEM" FontWeight="Black" Foreground="{Binding TextColorBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>

				<!-- ВОТ ЗДЕСЬ ИСПОЛЬЗУЕТСЯ SensorsPanel -->
				<StackPanel x:Name="SensorsPanel">

					<!-- БЛОК CPU -->
					<StackPanel x:Name="BlockCpu" Margin="0,0,0,12">
						<Grid Margin="0,0,0,6">
							<TextBlock Text="CPU" Foreground="{Binding TextColorBrush}" Opacity="0.8" HorizontalAlignment="Left" FontWeight="Medium"/>
							<TextBlock Text="{Binding CpuText}" Foreground="{Binding TextColorBrush}" HorizontalAlignment="Right" FontWeight="Bold"/>
						</Grid>
						<Grid Height="30" Margin="0,0,0,6">
							<Polyline Points="{Binding CpuGraphPoints}" Stroke="#34C759" StrokeThickness="2" Stretch="Fill" StrokeLineJoin="Round"/>
						</Grid>
						<ProgressBar Style="{StaticResource IOSProgressBar}" Value="{Binding CpuValue}" Maximum="100" Height="6" Foreground="{Binding TextColorBrush}"/>
						<Grid Margin="0,6,0,0" x:Name="BlockCpuTemp">
							<TextBlock Text="TEMP" Foreground="{Binding TextColorBrush}" Opacity="0.6" FontSize="10" HorizontalAlignment="Left"/>
							<TextBlock Text="{Binding TempText}" Foreground="{Binding TextColorBrush}" Opacity="0.8" FontSize="10" HorizontalAlignment="Right" FontWeight="Bold"/>
						</Grid>
					</StackPanel>

					<!-- БЛОК GPU -->
					<StackPanel x:Name="BlockGpu" Margin="0,0,0,12">
						<Grid Margin="0,0,0,6">
							<TextBlock Text="GPU" Foreground="{Binding TextColorBrush}" Opacity="0.8" HorizontalAlignment="Left" FontWeight="Medium"/>
							<TextBlock Text="{Binding GpuText}" Foreground="{Binding TextColorBrush}" HorizontalAlignment="Right" FontWeight="Bold"/>
						</Grid>
						<Grid Height="30" Margin="0,0,0,6">
							<Polyline Points="{Binding GpuGraphPoints}" Stroke="#0A84FF" StrokeThickness="2" Stretch="Fill" StrokeLineJoin="Round"/>
						</Grid>
						<ProgressBar Style="{StaticResource IOSProgressBar}" Value="{Binding GpuValue}" Maximum="100" Height="6" Foreground="{Binding TextColorBrush}"/>
					</StackPanel>

					<!-- БЛОК RAM -->
					<StackPanel x:Name="BlockRam" Margin="0,0,0,12">
						<Grid Margin="0,0,0,6">
							<TextBlock Text="RAM" Foreground="{Binding TextColorBrush}" Opacity="0.8" HorizontalAlignment="Left" FontWeight="Medium"/>
							<TextBlock Text="{Binding RamText}" Foreground="{Binding TextColorBrush}" HorizontalAlignment="Right" FontWeight="Bold"/>
						</Grid>
						<ProgressBar Style="{StaticResource IOSProgressBar}" Value="{Binding RamValue}" Maximum="100" Height="6" Foreground="{Binding TextColorBrush}"/>
					</StackPanel>

				</StackPanel>
			</StackPanel>
		</Grid>
	</Grid>
</widgets:BaseWidgetWindow>
    