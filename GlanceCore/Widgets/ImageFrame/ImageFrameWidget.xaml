<widgets:BaseWidgetWindow x:Class="GlanceCore.Widgets.ImageFrame.ImageFrameWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="clr-namespace:GlanceCore.Widgets"
        Title="Image Frame" WindowStyle="None" Background="Transparent" AllowsTransparency="True">

	<!-- Жестко фиксируем базовый размер. ScaleTransform из BaseWidgetWindow сделает остальное -->
	<Grid x:Name="MainRoot" Width="200" Height="200" Margin="15">
		<Grid.Effect>
			<DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
		</Grid.Effect>

		<!-- ClipToBounds="True" обрезает картинку по скругленным углам -->
		<Border CornerRadius="20" ClipToBounds="True" Background="#10FFFFFF" BorderBrush="{Binding BorderColorBrush}" BorderThickness="1.5">
			<!-- Stretch="UniformToFill" заполняет рамку без искажения пропорций лица/фото -->
			<Image x:Name="DisplayedImage" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
		</Border>
	</Grid>
</widgets:BaseWidgetWindow>