
<widgets:BaseWidgetWindow x:Class="GlanceCore.Widgets.StickyNotes.StickyNotesWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="clr-namespace:GlanceCore.Widgets"
        Title="Sticky Notes" WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

	<Grid x:Name="MainRoot" Width="220" Height="220" Margin="15">
		<Grid.Effect>
			<DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.4" Color="Black"/>
		</Grid.Effect>
		<Border x:Name="BackgroundLayer" CornerRadius="{Binding WidgetCornerRadius}" BorderBrush="{Binding BorderColorBrush}" BorderThickness="1.5" ClipToBounds="True" Opacity="{Binding BgOpacity}">
			<Grid>
				<Border x:Name="GlassBase" CornerRadius="{Binding WidgetCornerRadius}">
					<Border.Background>
						<ImageBrush x:Name="WallpaperBrush" Stretch="Fill"/>
					</Border.Background>
				</Border>
				<Border x:Name="MinimalBase" Background="{Binding BgColorBrush}" CornerRadius="{Binding WidgetCornerRadius}" Opacity="1"/>
				<Border Background="#20000000" CornerRadius="{Binding WidgetCornerRadius}"/>
				<Border x:Name="GlossBevel" CornerRadius="{Binding WidgetCornerRadius}" BorderBrush="#35FFFFFF" BorderThickness="1.5" Margin="1" IsHitTestVisible="False">
					<Border.Background>
						<RadialGradientBrush Center="0.5,0" RadiusX="0.9" RadiusY="0.6">
							<GradientStop Color="#25FFFFFF" Offset="0"/>
							<GradientStop Color="Transparent" Offset="1"/>
						</RadialGradientBrush>
					</Border.Background>
				</Border>
			</Grid>
		</Border>

		<TextBox x:Name="TxtNotes" Background="Transparent" Foreground="{Binding TextColorBrush}" FontSize="{Binding FontSize}" FontFamily="{Binding FontFamily}" BorderThickness="0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="15" CaretBrush="{Binding TextColorBrush}" TextChanged="TxtNotes_TextChanged" Effect="{Binding TextGlowEffect}"/>
	</Grid>
</widgets:BaseWidgetWindow>